# MLX-VLM 伺服器環境變數設定（複製為 .env 並根據需求修改）
#
# 設定優先順序：命令列參數 > 環境變數 > 預設值

# === 伺服器 ===
# MLX_VLM_HOST=0.0.0.0
# MLX_VLM_PORT=8080

# === 模型 ===
# MLX_VLM_MODEL=mlx-community/Qwen2.5-VL-7B-Instruct-4bit
# MLX_VLM_ADAPTER_PATH=
# MLX_VLM_TRUST_REMOTE_CODE=false

# === KV Cache 量化 ===
# MLX_VLM_KV_BITS=8
# MLX_VLM_KV_QUANT_SCHEME=uniform
# MLX_VLM_KV_GROUP_SIZE=64
# MLX_VLM_MAX_KV_SIZE=

# === 推測解碼（DFlash）===
# MLX_VLM_DRAFT_MODEL=
# MLX_VLM_DRAFT_KIND=dflash
# MLX_VLM_DRAFT_BLOCK_SIZE=

# === 其他 ===
# MLX_VLM_VISION_CACHE_SIZE=20
# MLX_VLM_LOG_LEVEL=INFO
# MLX_VLM_TOP_LOGPROBS_K=0
