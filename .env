# MLX-VLM 伺服器環境變數設定
#
# 設定優先順序：命令列參數 > 環境變數 > 預設值

# === 伺服器 ===
# MLX_VLM_HOST=0.0.0.0
# MLX_VLM_PORT=8080

# === 模型 ===
# 主模型設定
MLX_VLM_MODEL=mlx-community/gemma-4-e4b-it-4bit
# MLX_VLM_ADAPTER_PATH=
# MLX_VLM_TRUST_REMOTE_CODE=false

# === KV Cache 量化 ===
# 針對 M4 的預設最佳化設定
# MLX_VLM_KV_BITS=4.0
# MLX_VLM_KV_QUANT_SCHEME=turboquant
# MLX_VLM_KV_GROUP_SIZE=64
# MLX_VLM_MAX_KV_SIZE=

# === 推測解碼（DFlash）===
# 設定 gemma-4 assistant 作為草稿模型來加速生成
MLX_VLM_DRAFT_MODEL=mlx-community/gemma-4-E4B-it-assistant-bf16
MLX_VLM_DRAFT_KIND=dflash
# MLX_VLM_DRAFT_BLOCK_SIZE=

# === 其他 ===
# MLX_VLM_VISION_CACHE_SIZE=20
# MLX_VLM_LOG_LEVEL=INFO
# MLX_VLM_TOP_LOGPROBS_K=0
